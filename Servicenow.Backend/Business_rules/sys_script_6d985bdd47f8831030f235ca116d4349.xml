<script><![CDATA[(function executeRule(current, previous) {

    var team = new GlideRecord('u_teams');

    if(team.get(current.u_team)) {

        if(team.u_current_members_count >=
           team.u_max_members) {

            gs.addErrorMessage(
            'Team is already full');

            current.setAbortAction(true);
        }
    }

})(current, previous);]]></script>
