<script><![CDATA[function onLoad() {

    var status = g_form.getValue('u_application_status');

    var field = g_form.getControl('u_application_status');

    if (status == 'Selected') {

        field.style.backgroundColor = '#5cd65c';

    } else if (status == 'Rejected') {

        field.style.backgroundColor = '#ff4d4d';

    } else if (status == 'Under Review') {

        field.style.backgroundColor = '#ffa64d';
    }
}]]></script>
